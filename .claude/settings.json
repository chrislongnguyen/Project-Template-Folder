{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish)",
      "Bash(git push --force *)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(./scripts/dsbv-gate.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/resume-check.sh",
            "timeout": 5,
            "statusMessage": "Loading session context..."
          },
          {
            "type": "command",
            "command": "./.claude/hooks/session-reconstruct.sh",
            "timeout": 10,
            "statusMessage": "Reconstructing session state..."
          },
          {
            "type": "command",
            "command": "./scripts/pkb-lint.sh",
            "timeout": 10,
            "statusMessage": "Checking PKB health..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/verify-deliverables.sh",
            "timeout": 10,
            "statusMessage": "Verifying sub-agent deliverables..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/save-context-state.sh",
            "timeout": 10,
            "statusMessage": "Saving context state before compaction..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel)\" && ./.claude/hooks/session-summary.sh'",
            "timeout": 10,
            "statusMessage": "Saving session summary..."
          },
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel)\" && ./scripts/pkb-ingest-reminder.sh'",
            "timeout": 5,
            "statusMessage": "Checking for uningested knowledge..."
          },
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel)\" && ./scripts/pkb-lint.sh'",
            "timeout": 10,
            "statusMessage": "Checking PKB health..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/naming-lint.sh",
            "timeout": 5,
            "statusMessage": "Checking filename naming convention..."
          }
        ]
      },
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/dsbv-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking DSBV workstream boundaries..."
          },
          {
            "type": "command",
            "command": "bash -c 'if git diff --cached --name-only | grep -qE \"(SKILL\\.md|/skills/)\"; then ./scripts/skill-validator.sh --staged; fi'",
            "timeout": 15,
            "statusMessage": "Validating skill quality (EOP governance)..."
          },
          {
            "type": "command",
            "command": "./scripts/link-validator.sh --staged",
            "timeout": 3,
            "statusMessage": "Checking for broken wikilinks..."
          },
          {
            "type": "command",
            "command": "./scripts/registry-sync-check.sh",
            "timeout": 3,
            "statusMessage": "Checking VERSION_REGISTRY sync..."
          },
          {
            "type": "command",
            "command": "./scripts/status-guard.sh",
            "timeout": 3,
            "statusMessage": "Blocking agent self-approve..."
          },
          {
            "type": "command",
            "command": "python3 ./scripts/validate-blueprint.py --staged --quiet",
            "timeout": 5,
            "statusMessage": "Validating filesystem routing..."
          },
          {
            "type": "command",
            "command": "bash -c 'if git diff --cached --name-only | grep -qE \"^[1-5]-|^_genesis/\"; then git diff --cached --name-only | grep -q \"CHANGELOG.md\" || { echo \"WARN: workstream artifact staged but CHANGELOG.md not updated\" >&2; }; fi'",
            "timeout": 3,
            "statusMessage": "Checking changelog hygiene..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/dsbv-skill-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking DSBV Design phase prerequisite..."
          },
          {
            "type": "command",
            "command": "./scripts/dsbv-gate.sh --pretool",
            "timeout": 5,
            "statusMessage": "Checking ALPEI chain-of-custody..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/verify-agent-dispatch.sh",
            "timeout": 5,
            "statusMessage": "Verifying agent dispatch context packaging..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/strategic-compact.sh",
            "timeout": 5,
            "statusMessage": "Checking context saturation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/naming-lint.sh",
            "timeout": 5,
            "statusMessage": "Linting frontmatter casing..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/nesting-depth-guard.sh",
            "timeout": 5,
            "statusMessage": "EP-13: logging Agent() dispatch..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/state-saver.sh",
            "timeout": 10,
            "statusMessage": "Saving session state..."
          },
          {
            "type": "command",
            "command": "bash -c 'FILE=\"${TOOL_INPUT_file_path:-${TOOL_INPUT_path:-}}\"; if [[ \"$FILE\" == *.md ]]; then ./scripts/ripple-check.sh \"$(basename \"$FILE\")\" . | head -20; fi'",
            "timeout": 5,
            "statusMessage": "Checking backlink ripple..."
          }
        ]
      }
    ]
  }
}
