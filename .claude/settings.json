{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish)",
      "Bash(git push --force *)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(./scripts/dsbv-gate.sh)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/dsbv-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking DSBV zone boundaries..."
          },
          {
            "type": "command",
            "command": "bash -c 'if git diff --cached --name-only | grep -qE \"(SKILL\\.md|/skills/)\"; then ./scripts/skill-validator.sh --staged; fi'",
            "timeout": 15,
            "statusMessage": "Validating skill quality (EOP governance)..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/dsbv-skill-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking DSBV Design phase prerequisite..."
          }
        ]
      }
    ]
  }
}
