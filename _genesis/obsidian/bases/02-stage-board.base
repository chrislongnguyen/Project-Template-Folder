filters:
  and:
    - or:
        - work_stream == "1-ALIGN"
        - work_stream == "2-LEARN"
        - work_stream == "3-PLAN"
        - work_stream == "4-EXECUTE"
        - work_stream == "5-IMPROVE"
formulas:
  days_in_stage: (now() - file.mtime).days.round(0)
  stage_order: if(stage == "design", "1", if(stage == "sequence", "2", if(stage == "build", "3", if(stage == "validate", "4", "0"))))
  pipeline_position: if(stage, stage + " (" + work_stream + ")", "")
properties:
  file.name:
    displayName: DELIVERABLE
  stage:
    options:
      - value: design
        color: purple
      - value: sequence
        color: blue
      - value: build
        color: green
      - value: validate
        color: red
    displayName: STAGE
  status:
    options:
      - value: draft
        color: gray
      - value: in-progress
        color: yellow
      - value: in-review
        color: purple
      - value: validated
        color: green
      - value: archived
        color: gray
    displayName: STATUS
  sub_system:
    displayName: SUB-SYSTEM
  work_stream:
    options:
      - value: 1-ALIGN
        color: blue
      - value: 2-LEARN
        color: cyan
      - value: 3-PLAN
        color: yellow
      - value: 4-EXECUTE
        color: orange
      - value: 5-IMPROVE
        color: green
    displayName: WORK STREAM
  version:
    displayName: VERSION
  formula.days_in_stage:
    displayName: DAYS IN STAGE
views:
  - type: table
    name: PIPELINE (by stage)
    groupBy:
      property: stage
      direction: ASC
    order:
      - file.name
      - sub_system
      - work_stream
      - status
      - version
      - formula.days_in_stage
    sort:
      - property: work_stream
        direction: DESC
      - property: sub_system
        direction: DESC
  - type: table
    name: BY STATUS
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - sub_system
      - work_stream
      - stage
      - formula.days_in_stage
  - type: table
    name: DESIGN ITEMS
    filters:
      and:
        - stage == "design"
    order:
      - file.name
      - sub_system
      - work_stream
      - status
      - formula.days_in_stage
  - type: table
    name: SEQUENCE ITEMS
    filters:
      and:
        - stage == "sequence"
    order:
      - file.name
      - sub_system
      - work_stream
      - status
      - formula.days_in_stage
  - type: table
    name: BUILD ITEMS
    filters:
      and:
        - stage == "build"
    order:
      - file.name
      - sub_system
      - work_stream
      - status
      - formula.days_in_stage
  - type: table
    name: VALIDATE ITEMS
    filters:
      and:
        - stage == "validate"
    order:
      - file.name
      - sub_system
      - work_stream
      - status
      - formula.days_in_stage
