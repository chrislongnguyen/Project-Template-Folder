# Secrets — NEVER commit
.env
.env.local
.env.production
.env.*
!.env.example
secrets/
.backup/

# Security — prevent accidental credential commits
*.pem
*.key
*.p12
*.pfx
*.jks

# Personal agent config (Job Site personal overrides)
.claude/settings.local.json
.claude/worktrees/
.worktrees/
.template-version

# Superpowers working artifacts (specs/plans are local-only)
docs/superpowers/specs/
docs/superpowers/plans/

# Dependencies
node_modules/
.venv/
__pycache__/

# Build output
dist/
build/
.next/
out/
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# PKB — personal content, not shipped with template
