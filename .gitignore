# Secrets — NEVER commit
.env
.env.local
.env.production
.env.*
!.env.example
secrets/
.backup/

# Security — prevent accidental credential commits
*.pem
*.key
*.p12
*.pfx
*.jks

# Personal Knowledge Base — captured/ is gitignored (raw sources, often large)
PERSONAL-KNOWLEDGE-BASE/captured/

# Personal agent config (Job Site personal overrides)
.claude/settings.local.json
.claude/worktrees/
.worktrees/
.template-version

# Superpowers working artifacts (specs/plans are local-only)
docs/superpowers/specs/
docs/superpowers/plans/

# Dependencies
node_modules/
.venv/
__pycache__/

# Build output
dist/
build/
.next/
out/

# IDE
.vscode/
.idea/
.obsidian/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
.env
