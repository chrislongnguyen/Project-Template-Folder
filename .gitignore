# Secrets — NEVER commit
.env
.env.local
.env.production
.env.*
!.env.example
secrets/
.backup/

# Security — prevent accidental credential commits
*.pem
*.key
*.p12
*.pfx
*.jks

# Personal agent config (Job Site personal overrides)
.claude/settings.local.json
.claude/worktrees/
.worktrees/
.template-version

# Local documentation (appearance notes, superpowers artifacts)
docs/

# Archived reference material (historical, not shipped with template)
_genesis/reference/archive/

# Dependencies
node_modules/
.venv/
__pycache__/

# Build output
dist/
build/
.next/
out/
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# PKB — personal content, never shipped with template
# Only .gitkeep and README.md are tracked (structural scaffolding)
PERSONAL-KNOWLEDGE-BASE/1-captured/*
!PERSONAL-KNOWLEDGE-BASE/1-captured/.gitkeep
!PERSONAL-KNOWLEDGE-BASE/1-captured/README.md
PERSONAL-KNOWLEDGE-BASE/2-organised/*
!PERSONAL-KNOWLEDGE-BASE/2-organised/.gitkeep
!PERSONAL-KNOWLEDGE-BASE/2-organised/README.md
PERSONAL-KNOWLEDGE-BASE/3-distilled/*
!PERSONAL-KNOWLEDGE-BASE/3-distilled/.gitkeep
!PERSONAL-KNOWLEDGE-BASE/3-distilled/README.md
!PERSONAL-KNOWLEDGE-BASE/3-distilled/_index.md
PERSONAL-KNOWLEDGE-BASE/4-expressed/*
!PERSONAL-KNOWLEDGE-BASE/4-expressed/.gitkeep
!PERSONAL-KNOWLEDGE-BASE/4-expressed/README.md
PERSONAL-KNOWLEDGE-BASE/dashboard.md
PERSONAL-KNOWLEDGE-BASE/knowledge-map.canvas
PERSONAL-KNOWLEDGE-BASE/*.canvas

# inbox/ — WIP staging, personal captures, research drafts — never shipped
# Only .gitkeep and README.md are tracked (structural scaffolding)
inbox/*
!inbox/.gitkeep
!inbox/README.md

# Excalidraw/ — personal drawings, not for clone users
Excalidraw/

# Runtime state — never commit
.claude/state/
.claude/logs/

# Personal workspace config — never commit
*.code-workspace

# IDE
.vscode/
.idea/
.obsidian/

# OS
.DS_Store
Thumbs.db

# Temporary output
TEMP OUT/

# Orphaned lock files (training slides generate these at root)
/package-lock.json

# Logs
*.log
npm-debug.log*
.env

# Local tools (not shipped with template)
tools/
